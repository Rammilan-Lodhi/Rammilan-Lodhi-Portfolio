# ============================================================
# .gitignore — pnpm monorepo + portfolio (Vercel / Render)
# ============================================================

# ─── Dependencies ───────────────────────────────────────────
node_modules/
.pnpm-store/
.pnpm-debug.log

# ─── Environment variables ──────────────────────────────────
# Ignore ALL .env variants to prevent accidental secret commits.
# Add a committed .env.example / .env.sample as documentation instead.
.env*
!.env.example
!.env.sample

# ─── Build outputs ──────────────────────────────────────────
# Vite / React frontend (Vercel)
dist/
dist-ssr/
build/
out/

# TypeScript composite build cache (lib/* packages)
*.tsbuildinfo
tsconfig.tsbuildinfo

# esbuild bundle (api-server)
artifacts/api-server/dist/

# ─── pnpm / lockfile hygiene ────────────────────────────────
# Keep pnpm-lock.yaml committed for reproducible installs.
# Discard other lockfiles — only pnpm is supported here.
package-lock.json
yarn.lock

# ─── Drizzle ORM ────────────────────────────────────────────
# Generated migration SQL can be re-generated; keep schema source.
# Scoped to the actual DB package to avoid hiding unrelated folders.
lib/db/drizzle/
# Uncomment if you want to commit migrations:
# !lib/db/migrations/

# ─── Logs ───────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Testing ────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ─── Caches ─────────────────────────────────────────────────
.cache/
.parcel-cache/
.turbo/
.eslintcache
.stylelintcache
.vite/

# Orval codegen cache (regenerate with `pnpm --filter @workspace/api-spec run codegen`)
# Codegen outputs are committed so CI/CD can build without running codegen.
# If you prefer to regenerate on CI, uncomment the lines below:
# lib/api-client-react/src/generated/
# lib/api-zod/src/generated/

# ─── Vercel ─────────────────────────────────────────────────
.vercel/
.vercel

# ─── Render ─────────────────────────────────────────────────
# No special files; env vars are set in the Render dashboard.

# ─── OS files ───────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Editor / IDE ───────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# ─── Replit-specific ────────────────────────────────────────
# .replit and replit.nix are intentional workspace config — keep them tracked.
.upm/
.config/
.local/

# ─── Temporary / misc ───────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.orig

# ─── Portfolio — backend (Render) ───────────────────────────
# backend/.env              ← already covered by root .env* rule
portfolio/backend/node_modules/
portfolio/backend/dist/

# ─── Portfolio — frontend (Vercel) ──────────────────────────
# frontend/.env             ← already covered by root .env* rule
portfolio/frontend/node_modules/
portfolio/frontend/dist/
portfolio/frontend/.cache/